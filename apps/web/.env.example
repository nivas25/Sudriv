# =============================================================================
# Sudriv Web (Next.js) — copy to .env.local for local dev
# On Vercel: Project → Settings → Environment Variables
# =============================================================================

# Supabase (public)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Supabase (server only — never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# LiveKit (public URL + server secrets for token minting)
NEXT_PUBLIC_LIVEKIT_URL=wss://YOUR_PROJECT.livekit.cloud
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret
