# =============================================================================
# Sudriv Voice Agent — copy to .env for local dev
# On Railway: Service → Variables
# =============================================================================

# LiveKit Cloud (worker registration + room jobs)
LIVEKIT_URL=wss://YOUR_PROJECT.livekit.cloud
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret

# Supabase (service role — agent mutates running_orders / segments)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
# SUPABASE_SERVICE_ROLE_KEY=   # accepted as alias of SUPABASE_SERVICE_KEY

# Upstash Redis (hot running-order cache)
UPSTASH_REDIS_URL=rediss://default:YOUR_TOKEN@YOUR_HOST.upstash.io:6379

# OpenAI (conversation LLM + tool calling)
OPENAI_API_KEY=your-openai-api-key
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_MAX_COMPLETION_TOKENS=220

# Sarvam (STT + TTS)
SARVAM_API_KEY=your-sarvam-api-key
# SARVAM_STT_LANGUAGE=hi-IN
# SARVAM_TTS_SPEAKER=priya
# SARVAM_TTS_LANGUAGE=hi-IN

# Ops (Railway sets PORT automatically)
# PORT=8081
# SUDRIV_LOG_LEVEL=INFO
