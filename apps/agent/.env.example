# =============================================================================
# Sudriv Agent — Railway / local production env
# =============================================================================

# LiveKit Cloud (required)
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret

# Supabase (service role — agent writes running orders / segments)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
# Alias also accepted: SUPABASE_SERVICE_ROLE_KEY

# Redis (Upstash rediss://… or redis://…)
UPSTASH_REDIS_URL=rediss://default:TOKEN@HOST:6379

# OpenAI LLM
OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_MAX_COMPLETION_TOKENS=220

# Sarvam STT + TTS
SARVAM_API_KEY=your-sarvam-api-key
# SARVAM_STT_LANGUAGE=hi-IN
# SARVAM_TTS_SPEAKER=priya
# SARVAM_TTS_LANGUAGE=hi-IN

# Ops
# PORT=8081                    # Railway sets this; health server binds here
# SUDRIV_LOG_LEVEL=INFO
