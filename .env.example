# =============================================================================
# Sudriv — Environment Variables (template only — NO real secrets)
#
# Copy values into:
#   apps/web/.env.local     → frontend (Vercel mirrors these)
#   apps/agent/.env         → voice agent (Railway mirrors these)
#
# Never commit .env / .env.local files.
# =============================================================================

# ── Shared: Supabase ─────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Agent also accepts:
# SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# ── Shared: LiveKit Cloud ────────────────────────────────────────────────────
NEXT_PUBLIC_LIVEKIT_URL=wss://YOUR_PROJECT.livekit.cloud
LIVEKIT_URL=wss://YOUR_PROJECT.livekit.cloud
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret

# ── Agent: Redis (Upstash) ───────────────────────────────────────────────────
UPSTASH_REDIS_URL=rediss://default:YOUR_TOKEN@YOUR_HOST.upstash.io:6379
# UPSTASH_REDIS_TOKEN=   # only if your client needs it separately

# ── Agent: AI providers ──────────────────────────────────────────────────────
OPENAI_API_KEY=your-openai-api-key
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_MAX_COMPLETION_TOKENS=220

SARVAM_API_KEY=your-sarvam-api-key
# SARVAM_STT_LANGUAGE=hi-IN
# SARVAM_TTS_SPEAKER=priya
# SARVAM_TTS_LANGUAGE=hi-IN
# SARVAM_TTS_PACE=0.95

# ── Agent: ops ───────────────────────────────────────────────────────────────
# PORT=8081
# SUDRIV_LOG_LEVEL=INFO
