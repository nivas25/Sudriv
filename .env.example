# =============================================================================
# Sudriv — Environment Variables (template)
#
# Frontend (Vercel / apps/web/.env.local):
#   NEXT_PUBLIC_*  + server secrets listed under "Web"
#
# Agent (Railway / apps/agent/.env):
#   copy apps/agent/.env.example
# =============================================================================

# ── Web (Vercel) ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

NEXT_PUBLIC_LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret

# Optional if web uses Upstash directly
# UPSTASH_REDIS_URL=
# UPSTASH_REDIS_TOKEN=

# ── Agent (Railway) — also see apps/agent/.env.example ───────────────────────
# LIVEKIT_URL=
# LIVEKIT_API_KEY=
# LIVEKIT_API_SECRET=
# SUPABASE_URL=
# SUPABASE_SERVICE_KEY=
# UPSTASH_REDIS_URL=
# OPENAI_API_KEY=
# SARVAM_API_KEY=
